{
  "version": 2,
  "builds": [
    {
      "src": "workshop_portal/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.10"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "workshop_portal/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "workshop_portal.settings",
    "DJANGO_ENV": "production"
  }
}
