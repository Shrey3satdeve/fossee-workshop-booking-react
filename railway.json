{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python manage.py migrate --run-syncdb && gunicorn workshop_portal.wsgi --bind 0.0.0.0:$PORT --log-file -",
    "healthcheckPath": "/api/csrf/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
